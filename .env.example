# Deployment Manager
# Public hostname — nginx vhost + Cloudflare tunnel route when connected
DEPLOYMENT_MANAGER_HOST=domain.to.access.manager.com
DEPLOYMENT_MANAGER_AUTH_EMAIL=changeto@yourdomain.com
DEPLOYMENT_MANAGER_AUTH_PASSWORD=changeme098
BETTER_AUTH_SECRET=changeme567
# Days after inactive/failed before deployment log files and deployment_logs rows are deleted (default 90)
LOG_RETENTION_DAYS=90

# Shared Postgres DB superuser credentials
POSTGRES_USER=portaunext
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=portaunext

# Image Optimization
# Public hostname — nginx vhost + Cloudflare tunnel route when connected
IMGPROXY_HOST=cdn.yourdomain.com

# Cloudflare (optional — cache purge + tunnel automation)
# Prefer connecting via Settings → Cloudflare in the deployment manager UI.
# Legacy env fallback (scoped API token + account ID):
CLOUDFLARE_API_KEY=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# Optional legacy global API key auth (deprecated):
# CLOUDFLARE_API_EMAIL=your_cloudflare_api_email
# Optional env fallback tunnel selection:
# CLOUDFLARE_TUNNEL_ID=your_tunnel_uuid
# CLOUDFLARE_TUNNEL_NAME=my-tunnel
# CLOUDFLARE_TUNNEL_ORIGIN_URL=http://localhost

# Minio Configuration
# Public hostname — nginx vhost + Cloudflare tunnel route when connected
MINIO_HOST=storage.yourdomain.com
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# port-schedule (HTTP cron service; same Postgres DB, schema port_schedule)
# Long random secret — deployment-manager will use this for PUT /admin/apps/:id/credentials
PORT_SCHEDULE_MASTER_API_KEY=changeme_generate_a_long_random_secret
# First boot: set to "true" to run SQL migrations on start, then "false"
PORT_SCHEDULE_MIGRATE_ON_START=false
# Host port mapped to container 8080 (optional; for local API access before nginx)
PORT_SCHEDULE_HOST_PORT=8085
# Optional: public hostname; nginx vhost + Cloudflare tunnel route when connected
PORT_SCHEDULE_HOST=schedule.yourdomain.com
# App containers always get PORT_SCHEDULE_URL=http://port-schedule:8080 (Compose service; fixed in code).

# Umami analytics (shared instance; dedicated DB on shared Postgres)
# Public hostname — nginx vhost + Cloudflare tunnel route when UMAMI_HOST is set and Cloudflare connected
UMAMI_HOST=analytics.yourdomain.com
UMAMI_APP_SECRET=changeme_generate_with_openssl_rand_hex_32
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=changeme_umami_db_password
# Platform admin — deployment-manager syncs these to Umami on startup (replaces default admin/umami)
UMAMI_ADMIN_USERNAME=admin
UMAMI_ADMIN_PASSWORD=changeme_umami_admin_password
